# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Set true only to run API without DB (degraded mode)
ALLOW_START_WITHOUT_DB=false

# ── MongoDB ──────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/solvagence_careers
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/solvagence_careers
MONGO_URI=mongodb://localhost:27017/solvagence_careers
# Optional fallback when SRV DNS is blocked in your network:
# MONGO_URI_FALLBACK=mongodb://<user>:<pass>@host1:27017,host2:27017,host3:27017/solvagence_careers?replicaSet=<rs>&ssl=true&authSource=admin
# Optional auth source override (only if needed by your cluster)
# MONGO_AUTH_SOURCE=admin
# Optional DNS family (4 helps Atlas connectivity in some WSL/corporate networks)
# MONGO_DNS_FAMILY=4

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=solvagence_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=8h

# ── AWS S3 (Resume Storage) ───────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=solvagence-careers-resumes

# ── Admin Seed Credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Solvagence@2025!

# ── Frontend Origin (CORS) ────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ── Admin Safety Controls ──────────────────────────────────────────
# Keep this false/empty in production unless you explicitly want the
# admin dashboard to be able to reseed and reset portal data.
ALLOW_ADMIN_RESET=false

# ── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
